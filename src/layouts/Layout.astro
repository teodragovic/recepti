---
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
}

const { title, description = 'Recepti' } = Astro.props;
---

<!doctype html>
<html lang="hr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <main>
            <slot />
        </main>
    </body>
</html>
